BOT_TOKEN=__set_me__
DATABASE_URL=postgresql+asyncpg://cybermate:cybermate123@localhost:5432/cybermate
LOG_LEVEL=INFO

# WebApp authentication. Set WEBAPP_AUTH_REQUIRED=true in production
# (verifies Telegram WebApp HMAC). For local browser testing set
# WEBAPP_AUTH_REQUIRED=false and a fake user id via WEBAPP_DEV_USER_ID.
WEBAPP_AUTH_REQUIRED=true
WEBAPP_DEV_USER_ID=

# Public URL of the deployed mini-app. Pasted into the /start "Open Cyber Mate"
# button. Leave empty to send the welcome message without a button.
WEBAPP_URL=
