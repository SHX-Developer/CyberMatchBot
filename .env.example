############################################
# Cyber Mate · production .env
# Заполните и сохраните как .env (НЕ коммить!).
############################################

# ── Postgres ───────────────────────────────────────────────
POSTGRES_USER=cybermate
POSTGRES_PASSWORD=__strong_password_change_me__
POSTGRES_DB=cybermate

# ── Telegram ───────────────────────────────────────────────
BOT_TOKEN=__token_from_BotFather__

# Публичный HTTPS-URL мини-аппа (например: https://cybermate.example.com)
# Подставится в кнопку «Открыть Cyber Mate» в /start.
# Также используется в BotFather → /newapp.
WEBAPP_URL=https://example.com

# ── WebApp authentication ─────────────────────────────────
# В production оставьте true: бэк проверяет HMAC от Telegram.
# false — режим разработки (бэк примет X-Dev-User-Id).
WEBAPP_AUTH_REQUIRED=true
WEBAPP_DEV_USER_ID=

# ── Misc ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# Хост-порт для frontend в standalone-режиме (`docker compose up`).
# В Dokploy/Traefik этой переменной можно пренебречь — там трафик
# направляется через reverse proxy.
FRONTEND_PORT=8080
